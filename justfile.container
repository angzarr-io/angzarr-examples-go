# Go poker examples - container version
# This file is mounted as 'justfile' inside the container
# Also used directly in CI container jobs

set shell := ["bash", "-c"]

ROOT := `git rev-parse --show-toplevel`

default:
    @just --list

# Generate protos for client library (required before build)
proto-gen:
    cd {{ROOT}} && buf generate

build: proto-gen
    go mod tidy && go build ./...

test-unit: proto-gen
    go mod tidy && go test -v ./tests/ -timeout=120s

test-acceptance: proto-gen
    PLAYER_URL="${PLAYER_URL:-localhost:1310}" go test -v -tags=acceptance ./tests/ -timeout=600s

mutation-test: proto-gen
    go mod tidy && go test -v -tags=mutation -run TestMutation -timeout 30m ./tests/

test: test-unit test-acceptance

fmt:
    gofmt -w .

lint:
    golangci-lint run

# Auto-format code
fmt-fix:
    gofmt -w .
